[
  {"content": "人生如逆旅，我亦是行人。", "source": "苏轼《临江仙》", "tags": "人生,古典"},
  {"content": "山重水复疑无路，柳暗花明又一村。", "source": "陆游《游山西村》", "tags": "希望,古典"},
  {"content": "长风破浪会有时，直挂云帆济沧海。", "source": "李白《行路难》", "tags": "励志,古典"},
  {"content": "曾经沧海难为水，除却巫山不是云。", "source": "元稹《离思》", "tags": "爱情,古典"},
  {"content": "愿得一心人，白头不相离。", "source": "卓文君《白头吟》", "tags": "爱情,古典"},
  {"content": "两情若是久长时，又岂在朝朝暮暮。", "source": "秦观《鹊桥仙》", "tags": "爱情,古典"},
  {"content": "问世间情为何物，直教生死相许。", "source": "元好问《摸鱼儿》", "tags": "爱情,古典"},
  {"content": "最是人间留不住，朱颜辞镜花辞树。", "source": "王国维《蝶恋花》", "tags": "时光,古典"},
  {"content": "落霞与孤鹜齐飞，秋水共长天一色。", "source": "王勃《滕王阁序》", "tags": "自然,古典"},
  {"content": "采菊东篱下，悠然见南山。", "source": "陶渊明《饮酒》", "tags": "自然,古典"},
  {"content": "海内存知己，天涯若比邻。", "source": "王勃《送杜少府之任蜀州》", "tags": "友情,古典"},
  {"content": "莫愁前路无知己，天下谁人不识君。", "source": "高适《别董大》", "tags": "友情,古典"},
  {"content": "天生我材必有用，千金散尽还复来。", "source": "李白《将进酒》", "tags": "自信,古典"},
  {"content": "会当凌绝顶，一览众山小。", "source": "杜甫《望岳》", "tags": "励志,古典"},
  {"content": "千磨万击还坚劲，任尔东西南北风。", "source": "郑燮《竹石》", "tags": "坚韧,古典"},
  {"content": "沉舟侧畔千帆过，病树前头万木春。", "source": "刘禹锡《酬乐天扬州初逢席上见赠》", "tags": "希望,古典"},
  {"content": "不畏浮云遮望眼，自缘身在最高层。", "source": "王安石《登飞来峰》", "tags": "格局,古典"},
  {"content": "纸上得来终觉浅，绝知此事要躬行。", "source": "陆游《冬夜读书示子聿》", "tags": "实践,古典"},
  {"content": "少年易老学难成，一寸光阴不可轻。", "source": "朱熹《劝学诗》", "tags": "时光,古典"},
  {"content": "黑发不知勤学早，白首方悔读书迟。", "source": "颜真卿《劝学》", "tags": "学习,古典"},
  {"content": "生活不止眼前的苟且，还有诗和远方的田野。", "source": "高晓松", "tags": "生活,文艺"},
  {"content": "愿你出走半生，归来仍是少年。", "source": "网络", "tags": "成长,文艺"},
  {"content": "世间所有的相遇，都是久别重逢。", "source": "电影《一代宗师》", "tags": "缘分,文艺"},
  {"content": "如果你认识从前的我，也许你会原谅现在的我。", "source": "张爱玲", "tags": "成长,文学"},
  {"content": "因为懂得，所以慈悲。", "source": "张爱玲", "tags": "爱情,文学"},
  {"content": "于千万人之中遇见你所遇见的人，于千万年之中，时间的无涯的荒野里，没有早一步，也没有晚一步。", "source": "张爱玲《爱》", "tags": "爱情,文学"},
  {"content": "我行过许多地方的桥，看过许多次数的云，喝过许多种类的酒，却只爱过一个正当最好年龄的人。", "source": "沈从文", "tags": "爱情,文学"},
  {"content": "世事如书，我偏爱你这一句，愿做个逗号，呆在你脚边。", "source": "张嘉佳《从你的全世界路过》", "tags": "爱情,文学"},
  {"content": "我希望有个如你一般的人，如山间清爽的风，如古城温暖的光。", "source": "张嘉佳《从你的全世界路过》", "tags": "爱情,文学"},
  {"content": "一个人的行走范围，就是他的世界。", "source": "北岛", "tags": "人生,文学"},
  {"content": "卑鄙是卑鄙者的通行证，高尚是高尚者的墓志铭。", "source": "北岛《回答》", "tags": "现实,文学"},
  {"content": "黑夜给了我黑色的眼睛，我却用它寻找光明。", "source": "顾城《一代人》", "tags": "希望,文学"},
  {"content": "面朝大海，春暖花开。", "source": "海子", "tags": "生活,文学"},
  {"content": "要有最朴素的生活，与最遥远的梦想。", "source": "七堇年", "tags": "梦想,文学"},
  {"content": "人生如茶，空杯以对，才有喝不完的好茶。", "source": "林清玄", "tags": "人生,文学"},
  {"content": "以清净心看世界，以欢喜心过生活。", "source": "林清玄", "tags": "人生,文学"},
  {"content": "生命是一场遇见，人来人往。", "source": "三毛", "tags": "人生,文学"},
  {"content": "一个人至少拥有一个梦想，有一个理由去坚强。", "source": "三毛", "tags": "梦想,文学"},
  {"content": "岁月极美，在于它必然的流逝。", "source": "三毛", "tags": "时光,文学"},
  {"content": "刻意去找的东西，往往是找不到的。天下万物的来和去，都有他的时间。", "source": "三毛", "tags": "人生,文学"},
  {"content": "所有的大人曾经都是小孩，虽然只有少数人记得。", "source": "《小王子》", "tags": "成长,经典"},
  {"content": "只有用心灵才能看清事物的本质，真正重要的东西是肉眼无法看见的。", "source": "《小王子》", "tags": "人生,经典"},
  {"content": "如果你要驯服一个人，就要冒着掉眼泪的危险。", "source": "《小王子》", "tags": "爱情,经典"},
  {"content": "生活才不是生命荒唐的编号，生活的意义在于生活本身。", "source": "《小王子》", "tags": "生活,经典"},
  {"content": "世界上只有一种真正的英雄主义，那就是在认清生活的真相后依然热爱生活。", "source": "罗曼·罗兰", "tags": "人生,经典"},
  {"content": "人生而自由，却无往不在枷锁之中。", "source": "卢梭", "tags": "人生,经典"},
  {"content": "我思故我在。", "source": "笛卡尔", "tags": "哲学,经典"},
  {"content": "未经审视的人生不值得度过。", "source": "苏格拉底", "tags": "哲学,经典"},
  {"content": "认识你自己。", "source": "苏格拉底", "tags": "哲学,经典"},
  {"content": "我们听到的一切都是一个观点，不是事实。我们看见的一切都是一个视角，不是真相。", "source": "马可·奥勒留", "tags": "哲学,经典"},
  {"content": "你担心什么，什么就控制你。", "source": "约翰·洛克", "tags": "心理,经典"},
  {"content": "人生天地之间，若白驹过隙，忽然而已。", "source": "《庄子》", "tags": "时光,古典"},
  {"content": "知足者常乐，贪欲者常忧。", "source": "《老子》", "tags": "人生,古典"},
  {"content": "上善若水，水善利万物而不争。", "source": "《老子》", "tags": "人生,古典"},
  {"content": "路漫漫其修远兮，吾将上下而求索。", "source": "屈原《离骚》", "tags": "追求,古典"},
  {"content": "穷且益坚，不坠青云之志。", "source": "王勃《滕王阁序》", "tags": "励志,古典"},
  {"content": "锲而舍之，朽木不折；锲而不舍，金石可镂。", "source": "《荀子》", "tags": "坚持,古典"},
  {"content": "业精于勤，荒于嬉；行成于思，毁于随。", "source": "韩愈", "tags": "学习,古典"},
  {"content": "博学之，审问之，慎思之，明辨之，笃行之。", "source": "《中庸》", "tags": "学习,古典"},
  {"content": "千里之行，始于足下。", "source": "《老子》", "tags": "行动,古典"},
  {"content": "不积跬步，无以至千里；不积小流，无以成江海。", "source": "《荀子》", "tags": "积累,古典"},
  {"content": "己所不欲，勿施于人。", "source": "《论语》", "tags": "处世,古典"},
  {"content": "三人行，必有我师焉。", "source": "《论语》", "tags": "学习,古典"},
  {"content": "学而不思则罔，思而不学则殆。", "source": "《论语》", "tags": "学习,古典"},
  {"content": "知者不惑，仁者不忧，勇者不惧。", "source": "《论语》", "tags": "人生,古典"},
  {"content": "逝者如斯夫，不舍昼夜。", "source": "《论语》", "tags": "时光,古典"},
  {"content": "天行健，君子以自强不息。", "source": "《周易》", "tags": "励志,古典"},
  {"content": "地势坤，君子以厚德载物。", "source": "《周易》", "tags": "品德,古典"},
  {"content": "星光不问赶路人，时光不负有心人。", "source": "网络", "tags": "励志,文艺"},
  {"content": "愿你眼中有光，心中有爱，脚下有路。", "source": "网络", "tags": "祝福,文艺"},
  {"content": "日子很长，过客很多，也不必太在意。", "source": "网络", "tags": "人生,文艺"},
  {"content": "念念不忘，必有回响。", "source": "李叔同", "tags": "坚持,文艺"},
  {"content": "凡是过往，皆为序章。", "source": "莎士比亚", "tags": "人生,经典"},
  {"content": "生存还是毁灭，这是一个问题。", "source": "莎士比亚《哈姆雷特》", "tags": "哲学,经典"},
  {"content": "爱所有人，信任少数人，不负任何人。", "source": "莎士比亚", "tags": "处世,经典"},
  {"content": "黑夜无论怎样悠长，白昼总会到来。", "source": "莎士比亚《麦克白》", "tags": "希望,经典"},
  {"content": "这是一个最好的时代，这是一个最坏的时代。", "source": "狄更斯《双城记》", "tags": "时代,经典"},
  {"content": "幸福的家庭都是相似的，不幸的家庭各有各的不幸。", "source": "托尔斯泰《安娜·卡列尼娜》", "tags": "人生,经典"},
  {"content": "人最宝贵的是生命，生命对于每个人只有一次。", "source": "奥斯特洛夫斯基", "tags": "人生,经典"},
  {"content": "生活不能等待别人来安排，要自己去争取和奋斗。", "source": "路遥《平凡的世界》", "tags": "励志,文学"},
  {"content": "既然选择了远方，便只顾风雨兼程。", "source": "汪国真", "tags": "励志,文学"},
  {"content": "没有比脚更长的路，没有比人更高的山。", "source": "汪国真", "tags": "励志,文学"},
  {"content": "你若盛开，清风自来。", "source": "网络", "tags": "成长,文艺"},
  {"content": "心若没有栖息的地方，到哪里都是在流浪。", "source": "三毛", "tags": "孤独,文学"},
  {"content": "我们笑着说再见，却深知再见遥遥无期。", "source": "《海上钢琴师》", "tags": "离别,经典"},
  {"content": "有些人浅薄，有些人金玉其外败絮其中，但是总有一天，你会遇到一个绚丽的人。", "source": "《怦然心动》", "tags": "爱情,经典"},
  {"content": "希望是美好的，也许是人间至善，而美好的事物永不消逝。", "source": "《肖申克的救赎》", "tags": "希望,经典"},
  {"content": "人生和电影不同，人生辛苦多了。", "source": "《天堂电影院》", "tags": "人生,经典"},
  {"content": "生活就像一盒巧克力，你永远不知道下一颗是什么味道。", "source": "《阿甘正传》", "tags": "人生,经典"},
  {"content": "真正的失败不是跌倒，而是拒绝站起来。", "source": "网络", "tags": "励志,文艺"},
  {"content": "你要悄悄拔尖，然后惊艳所有人。", "source": "网络", "tags": "励志,文艺"},
  {"content": "不辜负生活，不迷失方向。", "source": "网络", "tags": "生活,文艺"},
  {"content": "今天的努力，是幸运的伏笔。", "source": "网络", "tags": "励志,文艺"},
  {"content": "慢慢来，谁还没有一个努力的过程。", "source": "网络", "tags": "成长,文艺"},
  {"content": "最好的状态是未来可期。", "source": "网络", "tags": "希望,文艺"},
  {"content": "知足且坚定，温柔且上进。", "source": "网络", "tags": "人生,文艺"},
  {"content": "保持热爱，奔赴山海。", "source": "网络", "tags": "生活,文艺"},
  {"content": "凡是经历，皆为馈赠。", "source": "网络", "tags": "人生,文艺"},
  {"content": "万事都要全力以赴，包括开心。", "source": "网络", "tags": "生活,文艺"},
  {"content": "你被安稳地爱着呢，应该有做任何事的勇气。", "source": "网络", "tags": "温暖,文艺"},
  {"content": "做一个温柔的人，永远不卑不亢清澈善良。", "source": "网络", "tags": "成长,文艺"},
  {"content": "一花一世界，一叶一菩提。", "source": "佛经", "tags": "禅意,古典"},
  {"content": "菩提本无树，明镜亦非台。本来无一物，何处惹尘埃。", "source": "六祖慧能", "tags": "禅意,古典"},
  {"content": "行到水穷处，坐看云起时。", "source": "王维《终南别业》", "tags": "自然,古典"},
  {"content": "空山新雨后，天气晚来秋。", "source": "王维《山居秋暝》", "tags": "自然,古典"},
  {"content": "明月松间照，清泉石上流。", "source": "王维《山居秋暝》", "tags": "自然,古典"},
  {"content": "大漠孤烟直，长河落日圆。", "source": "王维《使至塞上》", "tags": "自然,古典"},
  {"content": "人生得意须尽欢，莫使金樽空对月。", "source": "李白《将进酒》", "tags": "人生,古典"},
  {"content": "抽刀断水水更流，举杯消愁愁更愁。", "source": "李白《宣州谢朓楼饯别校书叔云》", "tags": "愁绪,古典"},
  {"content": "仰天大笑出门去，我辈岂是蓬蒿人。", "source": "李白《南陵别儿童入京》", "tags": "自信,古典"},
  {"content": "安能摧眉折腰事权贵，使我不得开心颜。", "source": "李白《梦游天姥吟留别》", "tags": "傲骨,古典"},
  {"content": "无边落木萧萧下，不尽长江滚滚来。", "source": "杜甫《登高》", "tags": "自然,古典"},
  {"content": "出师未捷身先死，长使英雄泪满襟。", "source": "杜甫《蜀相》", "tags": "遗憾,古典"},
  {"content": "感时花溅泪，恨别鸟惊心。", "source": "杜甫《春望》", "tags": "忧国,古典"},
  {"content": "谁言寸草心，报得三春晖。", "source": "孟郊《游子吟》", "tags": "亲情,古典"},
  {"content": "春蚕到死丝方尽，蜡炬成灰泪始干。", "source": "李商隐《无题》", "tags": "爱情,古典"},
  {"content": "身无彩凤双飞翼，心有灵犀一点通。", "source": "李商隐《无题》", "tags": "爱情,古典"},
  {"content": "此情可待成追忆，只是当时已惘然。", "source": "李商隐《锦瑟》", "tags": "回忆,古典"},
  {"content": "相见时难别亦难，东风无力百花残。", "source": "李商隐《无题》", "tags": "离别,古典"},
  {"content": "旧时王谢堂前燕，飞入寻常百姓家。", "source": "刘禹锡《乌衣巷》", "tags": "变迁,古典"},
  {"content": "东边日出西边雨，道是无晴却有晴。", "source": "刘禹锡《竹枝词》", "tags": "爱情,古典"},
  {"content": "野火烧不尽，春风吹又生。", "source": "白居易《赋得古原草送别》", "tags": "生命,古典"},
  {"content": "同是天涯沦落人，相逢何必曾相识。", "source": "白居易《琵琶行》", "tags": "共鸣,古典"},
  {"content": "在天愿作比翼鸟，在地愿为连理枝。", "source": "白居易《长恨歌》", "tags": "爱情,古典"},
  {"content": "天长地久有时尽，此恨绵绵无绝期。", "source": "白居易《长恨歌》", "tags": "爱情,古典"},
  {"content": "大江东去，浪淘尽，千古风流人物。", "source": "苏轼《念奴娇·赤壁怀古》", "tags": "历史,古典"},
  {"content": "但愿人长久，千里共婵娟。", "source": "苏轼《水调歌头》", "tags": "祝福,古典"},
  {"content": "十年生死两茫茫，不思量，自难忘。", "source": "苏轼《江城子》", "tags": "思念,古典"},
  {"content": "回首向来萧瑟处，归去，也无风雨也无晴。", "source": "苏轼《定风波》", "tags": "豁达,古典"},
  {"content": "小舟从此逝，江海寄余生。", "source": "苏轼《临江仙》", "tags": "自由,古典"},
  {"content": "衣带渐宽终不悔，为伊消得人憔悴。", "source": "柳永《蝶恋花》", "tags": "爱情,古典"},
  {"content": "众里寻他千百度，蓦然回首，那人却在，灯火阑珊处。", "source": "辛弃疾《青玉案·元夕》", "tags": "缘分,古典"},
  {"content": "少年不识愁滋味，爱上层楼。爱上层楼，为赋新词强说愁。", "source": "辛弃疾《丑奴儿》", "tags": "成长,古典"},
  {"content": "物是人非事事休，欲语泪先流。", "source": "李清照《武陵春》", "tags": "伤感,古典"},
  {"content": "知否，知否？应是绿肥红瘦。", "source": "李清照《如梦令》", "tags": "自然,古典"},
  {"content": "寻寻觅觅，冷冷清清，凄凄惨惨戚戚。", "source": "李清照《声声慢》", "tags": "孤独,古典"},
  {"content": "人生若只如初见，何事秋风悲画扇。", "source": "纳兰性德《木兰花令》", "tags": "爱情,古典"},
  {"content": "我是人间惆怅客，知君何事泪纵横。", "source": "纳兰性德《浣溪沙》", "tags": "孤独,古典"},
  {"content": "一往情深深几许？深山夕照深秋雨。", "source": "纳兰性德《蝶恋花》", "tags": "爱情,古典"},
  {"content": "山有木兮木有枝，心悦君兮君不知。", "source": "《越人歌》", "tags": "暗恋,古典"},
  {"content": "玲珑骰子安红豆，入骨相思知不知。", "source": "温庭筠《南歌子词二首》", "tags": "相思,古典"},
  {"content": "曾经有一份真诚的爱情放在我面前，我没有珍惜。", "source": "电影《大话西游》", "tags": "爱情,经典"},
  {"content": "我的意中人是个盖世英雄，有一天他会踩着七色云彩来娶我。", "source": "电影《大话西游》", "tags": "爱情,经典"},
  {"content": "人如果没有梦想，那跟咸鱼有什么分别。", "source": "电影《少林足球》", "tags": "梦想,经典"},
  {"content": "做人如果没梦想，跟咸鱼有什么分别。", "source": "电影《少林足球》", "tags": "梦想,经典"},
  {"content": "出来混，迟早要还的。", "source": "电影《无间道》", "tags": "因果,经典"},
  {"content": "对不起，我是警察。", "source": "电影《无间道》", "tags": "身份,经典"},
  {"content": "往往都是事情改变人，人却改变不了事情。", "source": "电影《无间道》", "tags": "现实,经典"},
  {"content": "有人就有恩怨，有恩怨就有江湖。人就是江湖，你怎么退出。", "source": "电影《笑傲江湖之东方不败》", "tags": "江湖,经典"},
  {"content": "天下风云出我辈，一入江湖岁月催。", "source": "电影《笑傲江湖之东方不败》", "tags": "江湖,经典"},
  {"content": "人生不能像做菜，把所有的料都准备好了才下锅。", "source": "电影《饮食男女》", "tags": "人生,经典"},
  {"content": "如果你不出去走走，你就会以为这就是世界。", "source": "电影《天堂电影院》", "tags": "眼界,经典"},
  {"content": "你要尽全力保护你的梦想。那些嘲笑你梦想的人，他们必定会失败。", "source": "电影《当幸福来敲门》", "tags": "梦想,经典"},
  {"content": "机会总是留给有准备的人，但那往往是努力的人剩下来的。", "source": "电影《当幸福来敲门》", "tags": "励志,经典"},
  {"content": "不要让别人告诉你，你成不了才。", "source": "电影《当幸福来敲门》", "tags": "励志,经典"},
  {"content": "我们仰望同一片天空，却看着不同的地方。", "source": "《秒速五厘米》", "tags": "距离,经典"},
  {"content": "即使再悲伤也要勇敢活下去，这是人类的诅咒，但一定，也是一种祝福。", "source": "《追逐繁星的孩子》", "tags": "坚强,经典"},
  {"content": "不管你曾经被伤害得有多深，总会有一个人的出现，让你原谅之前生活对你所有的刁难。", "source": "《幽灵公主》", "tags": "治愈,经典"},
  {"content": "人生就是一列开往坟墓的列车，路途上会有很多站，很难有人可以自始至终陪着走完。", "source": "《千与千寻》", "tags": "人生,经典"},
  {"content": "不管前方的路有多苦，只要走的方向正确，不管多么崎岖不平，都比站在原地更接近幸福。", "source": "《千与千寻》", "tags": "坚持,经典"},
  {"content": "我只能送你到这里了，剩下的路你要自己走，不要回头。", "source": "《千与千寻》", "tags": "成长,经典"},
  {"content": "世界这么大，人生这么长，总会有这么一个人，让你想要温柔的对待。", "source": "《哈尔的移动城堡》", "tags": "爱情,经典"},
  {"content": "人哪有好的，只是坏的程度不一样而已。", "source": "《哈尔的移动城堡》", "tags": "人性,经典"},
  {"content": "生活坏到一定程度就会好起来，因为它无法更坏。", "source": "《龙猫》", "tags": "希望,经典"},
  {"content": "有些烦恼，丢掉了，才有云淡风轻的机会。", "source": "《龙猫》", "tags": "释然,经典"},
  {"content": "纵有疾风起，人生不言弃。", "source": "《起风了》", "tags": "励志,经典"},
  {"content": "你努力的每一天，都值得被记住。", "source": "网络", "tags": "励志,文艺"},
  {"content": "愿生活明朗，万物可爱。", "source": "网络", "tags": "生活,文艺"},
  {"content": "把自己活成一束光，自信坦荡，光芒万丈。", "source": "网络", "tags": "自信,文艺"},
  {"content": "热爱可抵岁月漫长。", "source": "网络", "tags": "热爱,文艺"},
  {"content": "愿你历尽山河，觉得人间值得。", "source": "网络", "tags": "人生,文艺"},
  {"content": "知足而上进，温柔且坚定。", "source": "网络", "tags": "人生,文艺"},
  {"content": "日子常新，未来不远。", "source": "网络", "tags": "希望,文艺"},
  {"content": "你未必光芒万丈，但始终温暖有光。", "source": "网络", "tags": "温暖,文艺"},
  {"content": "愿所有的不安，都是虚惊一场。", "source": "网络", "tags": "安慰,文艺"},
  {"content": "生活明朗，万物可爱，人间值得，未来可期。", "source": "网络", "tags": "祝福,文艺"},
  {"content": "跨过星河迈过月亮，去迎接更好的自己。", "source": "网络", "tags": "成长,文艺"},
  {"content": "愿你以渺小启程，以伟大结束。", "source": "网络", "tags": "祝福,文艺"},
  {"content": "所求皆如愿，所行化坦途。", "source": "网络", "tags": "祝福,文艺"},
  {"content": "岁岁常欢愉，万事皆胜意。", "source": "网络", "tags": "祝福,文艺"},
  {"content": "日子不慌不忙，我们来日方长。", "source": "网络", "tags": "时光,文艺"},
  {"content": "心有猛虎，细嗅蔷薇。", "source": "西格夫里·萨松", "tags": "刚柔,经典"},
  {"content": "生如夏花之绚烂，死如秋叶之静美。", "source": "泰戈尔", "tags": "生命,经典"},
  {"content": "如果你因失去了太阳而流泪，那么你也将失去群星了。", "source": "泰戈尔", "tags": "豁达,经典"},
  {"content": "世界以痛吻我，要我报之以歌。", "source": "泰戈尔", "tags": "坚强,经典"},
  {"content": "不要着急，最好的总会在最不经意的时候出现。", "source": "泰戈尔", "tags": "等待,经典"},
  {"content": "爱是理解的别名。", "source": "泰戈尔", "tags": "爱情,经典"},
  {"content": "天空没有翅膀的痕迹，但我已飞过。", "source": "泰戈尔", "tags": "人生,经典"},
  {"content": "你看不见你自己，你所看见的只是你的影子。", "source": "泰戈尔", "tags": "自我,经典"},
  {"content": "当你为错过太阳而哭泣的时候，你也要再错过群星了。", "source": "泰戈尔", "tags": "豁达,经典"},
  {"content": "每一个不曾起舞的日子，都是对生命的辜负。", "source": "尼采", "tags": "生命,经典"},
  {"content": "那些杀不死我的，必使我更强大。", "source": "尼采", "tags": "坚强,经典"},
  {"content": "一个人知道自己为什么而活，就可以忍受任何一种生活。", "source": "尼采", "tags": "人生,经典"},
  {"content": "没有可怕的深度，就没有美丽的水面。", "source": "尼采", "tags": "深度,经典"},
  {"content": "你要搞清楚自己人生的剧本，不是你父母的续集，不是你子女的前传。", "source": "尼采", "tags": "自我,经典"},
  {"content": "谦逊基于力量，高傲基于无能。", "source": "尼采", "tags": "处世,经典"},
  {"content": "所谓自由，不是只要做自己想做的事，而是可以不做自己不想做的事。", "source": "康德", "tags": "自由,经典"},
  {"content": "发怒，是用别人的错误来惩罚自己。", "source": "康德", "tags": "情绪,经典"},
  {"content": "三样东西有助于缓解生命的辛劳：希望，睡眠和微笑。", "source": "康德", "tags": "生活,经典"},
  {"content": "幸福是灵魂的一种香味。", "source": "罗曼·罗兰", "tags": "幸福,经典"},
  {"content": "真正的光明绝不是永没有黑暗的时间，只是永不被黑暗所掩蔽罢了。", "source": "罗曼·罗兰", "tags": "光明,经典"},
  {"content": "累累的创伤，就是生命给你的最好的东西，因为在每个创伤上都标示着前进的一步。", "source": "罗曼·罗兰", "tags": "成长,经典"},
  {"content": "世上只有一种英雄主义，就是在认清生活真相之后依然热爱生活。", "source": "罗曼·罗兰", "tags": "人生,经典"},
  {"content": "外表的美只能取悦于人的眼睛，而内在的美却能感染人的灵魂。", "source": "伏尔泰", "tags": "美,经典"},
  {"content": "我不同意你的观点，但我誓死捍卫你说话的权利。", "source": "伏尔泰", "tags": "自由,经典"},
  {"content": "使人疲惫的不是远方的高山，而是鞋里的一粒沙子。", "source": "伏尔泰", "tags": "细节,经典"},
  {"content": "人的一切痛苦，本质上都是对自己的无能的愤怒。", "source": "王小波", "tags": "现实,文学"},
  {"content": "一个人只拥有此生此世是不够的，他还应该拥有诗意的世界。", "source": "王小波", "tags": "生活,文学"},
  {"content": "我选择沉默的主要原因之一：从话语中，你很少能学到人性，从沉默中却能。", "source": "王小波", "tags": "沉默,文学"},
  {"content": "我来到这个世界，为了看看太阳。", "source": "巴尔蒙特", "tags": "生命,经典"},
  {"content": "愿你的生命中有够多的云翳，来造成一个美丽的黄昏。", "source": "冰心", "tags": "人生,文学"},
  {"content": "成功的花，人们只惊羡她现时的明艳！然而当初她的芽儿，浸透了奋斗的泪泉。", "source": "冰心", "tags": "成功,文学"},
  {"content": "墙角的花！你孤芳自赏时，天地便小了。", "source": "冰心", "tags": "眼界,文学"},
  {"content": "爱在左，同情在右，走在生命的两旁，随时撒种，随时开花。", "source": "冰心", "tags": "爱,文学"},
  {"content": "我们最终都要远行，最终都要跟稚嫩的自己告别。", "source": "海子", "tags": "成长,文学"},
  {"content": "你来人间一趟，你要看看太阳，和你的心上人，一起走在街上。", "source": "海子", "tags": "生活,文学"},
  {"content": "要有最朴素的生活，与最遥远的梦想。即使明日天寒地冻，路远马亡。", "source": "七堇年", "tags": "梦想,文学"},
  {"content": "人生如路，须在荒凉中走出繁华的风景来。", "source": "七堇年", "tags": "人生,文学"},
  {"content": "也许一个人要走很长的路，经历过生命中无数突如其来的繁华和苍凉才会变得成熟。", "source": "七堇年", "tags": "成熟,文学"},
  {"content": "我想要的，不过是可以活得像我自己。", "source": "三毛", "tags": "自我,文学"},
  {"content": "心，若没有栖息的地方，到哪里都是流浪。", "source": "三毛", "tags": "孤独,文学"},
  {"content": "每想你一次，天上飘落一粒沙，从此形成了撒哈拉。", "source": "三毛", "tags": "爱情,文学"},
  {"content": "如果有来生，要做一棵树，站成永恒，没有悲欢的姿势。", "source": "三毛", "tags": "人生,文学"},
  {"content": "走得突然，我们来不及告别。这样也好，因为我们永远不告别。", "source": "三毛", "tags": "离别,文学"},
  {"content": "人，真是奇怪，没有外人来证明你，就往往看不出自己的价值。", "source": "三毛", "tags": "自我,文学"},
  {"content": "一个人，大凡肯虚心反省自己的过失，以后就不会再重犯同样的错误。", "source": "三毛", "tags": "成长,文学"},
  {"content": "如果你给我的，和你给别人的是一样的，那我就不要了。", "source": "三毛", "tags": "爱情,文学"},
  {"content": "读书多了，容颜自然改变。", "source": "三毛", "tags": "读书,文学"},
  {"content": "生活，是一种缓缓如夏日流水般的前进，我们不要焦急。", "source": "三毛", "tags": "生活,文学"},
  {"content": "我来不及认真地年轻，待明白过来时，只能选择认真地老去。", "source": "三毛", "tags": "时光,文学"},
  {"content": "愿你慢慢长大，愿你有好运，如果没有，希望你在不幸中学会慈悲。", "source": "刘瑜", "tags": "祝福,文学"},
  {"content": "一个人就像一支队伍，对着自己的头脑和心灵招兵买马。", "source": "刘瑜", "tags": "自我,文学"},
  {"content": "在这个时代，也许最重要的不是忙着去叫醒别人，而是时刻扪心自问为何要装睡。", "source": "周濂", "tags": "觉醒,文学"},
  {"content": "没有比漫无目的地徘徊更令人无法忍受的了。", "source": "荷马", "tags": "方向,经典"},
  {"content": "人生的本质在于运动，安谧宁静就是死亡。", "source": "帕斯卡", "tags": "生命,经典"},
  {"content": "给时光以生命，而不是给生命以时光。", "source": "帕斯卡", "tags": "时光,经典"},
  {"content": "人是一根会思考的芦苇。", "source": "帕斯卡", "tags": "哲学,经典"},
  {"content": "生活在阴沟里，依然有仰望星空的权利。", "source": "王尔德", "tags": "希望,经典"},
  {"content": "我们都生活在阴沟里，但仍有人仰望星空。", "source": "王尔德", "tags": "希望,经典"},
  {"content": "做你自己，因为别人都有人做了。", "source": "王尔德", "tags": "自我,经典"},
  {"content": "爱自己，是终身浪漫的开始。", "source": "王尔德", "tags": "自爱,经典"},
  {"content": "比世人的目光还要可怕的，实际上是你自己那颗在意世人目光的心。", "source": "山本文绪", "tags": "自我,经典"},
  {"content": "所谓成长，就是在听到波涛汹涌四个字，再也联想不到大海了。", "source": "网络", "tags": "成长,文艺"},
  {"content": "我们终其一生，就是要摆脱他人的期待，找到真正的自己。", "source": "伍绮诗《无声告白》", "tags": "自我,文学"},
  {"content": "永远都不要为了目的而忘记初衷。", "source": "《小王子》", "tags": "初心,经典"},
  {"content": "如果你说你在下午四点来，从三点钟开始，我就开始感觉很快乐。", "source": "《小王子》", "tags": "期待,经典"},
  {"content": "仪式感就是使某一天与其他日子不同，使某一时刻与其他时刻不同。", "source": "《小王子》", "tags": "生活,经典"},
  {"content": "真正的世界无限广阔，一个充满希望与忧烦的世界，等待着有胆识的人去征服。", "source": "《简·爱》", "tags": "勇气,经典"},
  {"content": "你以为我贫穷、相貌平平就没有感情吗？我向你发誓，如果上帝赋予我财富和美貌，我会让你难以离开我。", "source": "《简·爱》", "tags": "自尊,经典"},
  {"content": "幸福的家庭都是相似的，不幸的家庭各有各的不幸。", "source": "托尔斯泰", "tags": "人生,经典"},
  {"content": "每个人都会有缺陷，就像被上帝咬过的苹果，有的人缺陷比较大，正是因为上帝特别喜欢他的芬芳。", "source": "托尔斯泰", "tags": "接纳,经典"},
  {"content": "人生的价值，并不是用时间，而是用深度去衡量的。", "source": "托尔斯泰", "tags": "价值,经典"},
  {"content": "生命中真正重要的不是你遭遇了什么，而是你记住了哪些事，又是如何铭记的。", "source": "马尔克斯《百年孤独》", "tags": "记忆,经典"},
  {"content": "无论走到哪里，都应该记住，过去都是假的，回忆是一条没有尽头的路。", "source": "马尔克斯《百年孤独》", "tags": "回忆,经典"},
  {"content": "生命中曾经有过的所有灿烂，终究都需要用寂寞来偿还。", "source": "马尔克斯《百年孤独》", "tags": "孤独,经典"},
  {"content": "过去都是假的，回忆没有归路，春天总是一去不返。", "source": "马尔克斯《百年孤独》", "tags": "时光,经典"},
  {"content": "当你凝视深渊时，深渊也在凝视着你。", "source": "尼采", "tags": "人性,经典"},
  {"content": "没有一种命运是对人的惩罚，而只要竭尽全力就应该是幸福的。", "source": "加缪", "tags": "幸福,经典"},
  {"content": "重要的不是治愈，而是带着病痛活下去。", "source": "加缪", "tags": "生命,经典"},
  {"content": "在隆冬，我终于知道，我身上有一个不可战胜的夏天。", "source": "加缪", "tags": "坚强,经典"},
  {"content": "不要走在我后面，因为我可能不会引路；不要走在我前面，因为我可能不会跟随。", "source": "加缪", "tags": "同行,经典"},
  {"content": "我的灵魂与我之间的距离如此遥远，而我的存在却如此真实。", "source": "加缪", "tags": "自我,经典"},
  {"content": "一个人如果知道自己为什么而活，就可以忍受任何一种生活。", "source": "弗兰克尔", "tags": "人生,经典"},
  {"content": "当华美的叶片落尽，生命的脉络才历历可见。", "source": "聂鲁达", "tags": "生命,经典"},
  {"content": "我喜欢你是寂静的，仿佛你消失了一样。", "source": "聂鲁达", "tags": "爱情,经典"},
  {"content": "爱情太短，而遗忘太长。", "source": "聂鲁达", "tags": "爱情,经典"},
  {"content": "你和我之间，只隔着一个微笑的距离。", "source": "聂鲁达", "tags": "爱情,经典"},
  {"content": "你若爱她，让你的爱像阳光一样包围她，并且给她自由。", "source": "泰戈尔", "tags": "爱情,经典"},
  {"content": "不要着急，最好的总会在最不经意的时候出现。", "source": "泰戈尔", "tags": "等待,经典"},
  {"content": "友谊和花香一样，还是淡一点的比较好，越淡的香气越使人依恋。", "source": "席慕容", "tags": "友情,文学"},
  {"content": "青春是一本太仓促的书，我们含着泪，一读再读。", "source": "席慕容", "tags": "青春,文学"},
  {"content": "在一回首间，才忽然发现，原来，我一生的种种努力，不过只为了周遭的人对我满意而已。", "source": "席慕容", "tags": "自我,文学"},
  {"content": "所有结局都已写好，所有泪水也都已启程。", "source": "席慕容", "tags": "青春,文学"},
